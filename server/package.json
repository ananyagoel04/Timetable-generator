{
  "name": "timetable-server",
  "version": "1.0.0",
  "description": "Advanced School Timetable ERP Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "worker:generation": "node workers/generationWorker.js",
    "dev:all": "npx -y concurrently \"npm run dev\" \"npm run worker:generation\"",
    "seed": "node seed/seedData.js --reset",
    "seed:reset": "node seed/seedData.js --reset",
    "seed:multi-school": "node seed/seedData.js",
    "seed:timetable-test": "node seed/seedData.js --reset",
    "seed:verify": "node seed/seedVerify.js",
    "seed:smoke": "node seed/seedSmoke.js",
    "seed:demo": "node seed/seedData.js --reset",
    "indexes:fix": "node scripts/fixIndexes.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.77.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "mongoose": "^8.7.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
